# ==============================
# BPMN Platform - Env Template
# ==============================
# Copia este archivo a .env y completa los valores reales.
# cp .env.example .env

# ---------- APP ----------
APP_NAME=core
APP_PUBLIC_BASE_URL=http://<EC2_PUBLIC_IP_OR_DOMAIN>
APP_BACKEND_PUBLIC_BASE_URL=http://backend:8080
JAVA_OPTS=-Xms256m -Xmx1024m
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:4200,http://127.0.0.1:4200

# ---------- BACKEND HTTP ----------
BACKEND_PORT=8080

# ---------- ONLYOFFICE DOCUMENT SERVER ----------
# URL visible desde el navegador del usuario para cargar api.js.
# Local Docker: http://localhost:8082
# Produccion: https://<dominio-onlyoffice-o-proxy>
ONLYOFFICE_DOCUMENT_SERVER_URL=http://localhost:8082
ONLYOFFICE_INTERNAL_DOCUMENT_SERVER_URL=http://onlyoffice
ONLYOFFICE_PRESIGNED_URL_HOURS=2

# ---------- MONGODB (ATLAS O AUTOGESTIONADO) ----------
# Producción recomendada: MongoDB Atlas con usuario de aplicación y IP restringidas.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# ---------- RABBITMQ (STOMP RELAY PARA WEBSOCKETS COLABORATIVOS) ----------
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_STOMP_PORT=61613
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# ---------- AWS S3 ----------
# Usa un IAM User/Role con permisos mínimos al bucket requerido.
AWS_REGION=sa-east-1
AWS_S3_BUCKET=politicas-bpmn-adjuntos-prod
AWS_ACCESS_KEY_ID=<your_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_secret_access_key>

# ---------- LÍMITES DE SUBIDA ----------
MAX_UPLOAD_SIZE=50MB
MAX_REQUEST_SIZE=50MB

# ---------- FRONTEND (opcional en build local) ----------
NODE_ENV=production

